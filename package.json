{
  "name": "web-permission-kit",
  "version": "0.0.1",
  "description": "TypeScript library bridging the Web Permissions API to a unified check/request interface — Notification, Geolocation, Camera, Microphone, Clipboard, MIDI, DeviceOrientation, DeviceMotion, PersistentStorage.",
  "author": "Park Jungyoung <qkrwnss0509@gmail.com> (https://github.com/pjy0509)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/permission-kit.cjs",
  "module": "dist/permission-kit.mjs",
  "browser": "dist/permission-kit.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/permission-kit.mjs",
      "require": "./dist/permission-kit.cjs",
      "default": "./dist/permission-kit.mjs"
    }
  },
  "files": [
    "dist/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjy0509/web-permission-kit.git"
  },
  "homepage": "https://pjy0509.github.io/example/web-permission-kit/",
  "keywords": [
    "permission",
    "permissions-api",
    "web-permissions",
    "notification",
    "geolocation",
    "camera",
    "microphone",
    "clipboard",
    "midi",
    "device-orientation",
    "device-motion",
    "persistent-storage",
    "browser",
    "webview",
    "pwa"
  ],
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "web-platform-kit": "^0.0.1"
  }
}
